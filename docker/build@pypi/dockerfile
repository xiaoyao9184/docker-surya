ARG SURYA_VERSION=0.20.0
ARG STREAMLIT_VERSION=1.40.2
ARG GRADIO_VERSION=5.8.0


FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS llama_cpp_builder

ARG LLAMA_CPP_REV=master
ARG RUST_VERSION=1.87.0

ENV CARGO_HOME=/opt/cargo
ENV RUSTUP_HOME=/opt/rustup
ENV PATH=/opt/cargo/bin:${PATH}

RUN apt-get update && apt-get install -y \
    ca-certificates \
    cmake \
    curl \
    g++ \
    git \
    ninja-build \
    && rm -rf /var/lib/apt/lists/*

RUN curl -L https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain ${RUST_VERSION}

RUN git clone https://github.com/ggml-org/llama.cpp.git /tmp/llama.cpp \
    && cd /tmp/llama.cpp \
    && git checkout ${LLAMA_CPP_REV} \
    && cmake -B build-cpu -G Ninja \
        -DLLAMA_LLGUIDANCE=ON \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_NATIVE=OFF \
    && cmake --build build-cpu --config Release --target llama-server \
    && ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1 \
    && cmake -B build-cuda -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DLLAMA_LLGUIDANCE=ON \
        -DGGML_CUDA=ON \
        -DGGML_NATIVE=OFF \
        -DCMAKE_EXE_LINKER_FLAGS="-Wl,-rpath-link,/usr/local/cuda/lib64/stubs" \
    && cmake --build build-cuda --config Release --target llama-server


FROM pytorch/pytorch:2.7.0-cuda12.6-cudnn9-runtime

ARG SURYA_VERSION
ARG STREAMLIT_VERSION
ARG GRADIO_VERSION

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3-pip \
    libgl1-mesa-glx \
    libsm6 \
    libxext6 \
    libglib2.0-0 \
    libgomp1 \
    libxrender-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=llama_cpp_builder /tmp/llama.cpp/build-cpu/bin /opt/llama.cpp/cpu
COPY --from=llama_cpp_builder /tmp/llama.cpp/build-cuda/bin /opt/llama.cpp/cuda

RUN printf '%s\n' \
    '#!/usr/bin/env sh' \
    'set -eu' \
    'if [ "${LLAMA_CPP_FORCE_CPU:-}" = "1" ]; then' \
    '    LLAMA_CPP_HOME=/opt/llama.cpp/cpu' \
    'elif [ -e /dev/nvidia0 ] || [ -e /dev/nvidiactl ]; then' \
    '    LLAMA_CPP_HOME=/opt/llama.cpp/cuda' \
    'else' \
    '    LLAMA_CPP_HOME=/opt/llama.cpp/cpu' \
    'fi' \
    'export LD_LIBRARY_PATH="${LLAMA_CPP_HOME}:${LD_LIBRARY_PATH:-}"' \
    'exec "${LLAMA_CPP_HOME}/llama-server" "$@"' \
    > /usr/local/bin/llama-server \
    && chmod +x /usr/local/bin/llama-server

RUN pip3 install --upgrade pip

RUN pip3 install --no-cache-dir \
    surya-ocr==${SURYA_VERSION} \
    transformers==4.56.1 \
    pdftext==0.5.0 \
    streamlit==${STREAMLIT_VERSION} \
    gradio==${GRADIO_VERSION} \
    pydantic==2.10.5 \
    gunicorn==22.0.0 \
    Flask==3.1.3 \
    colorama==0.4.6 \
    requests==2.34.2 \
    semver==3.0.4 \
    label-studio-sdk==1.0.10 \
    boto3==1.35.91
RUN pip3 install --no-deps \
    git+https://github.com/HumanSignal/label-studio-ml-backend.git@b06ebeb#egg=label-studio-ml

COPY ./gradio /workspace/gradio
COPY ./label /workspace/label

EXPOSE 8501
EXPOSE 7860
EXPOSE 9090

VOLUME /root/.cache
VOLUME /workspace/label/.pytest_cache
# VOLUME /workspace/label/cache.db

ENV APP_PATH=/app
ENV GRADIO_SERVER_NAME="0.0.0.0"
ENV LABEL_STUDIO_URL=http://label-studio:8080

CMD ["surya_gui"]
