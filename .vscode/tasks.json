{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "docker: compose up.label@gpu-offline",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/docker/up.label@gpu-offline/"
            },
            "command": "docker compose -p surya up"
        },
        {
            "label": "docker: compose up.gradio@gpu-offline",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/docker/up.gradio@gpu-offline/"
            },
            "command": "docker compose -p surya up"
        },
        {
            "label": "docker: compose up@cpu-online",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/docker/up@cpu-online/"
            },
            "command": "docker compose -p surya up",
        },
        {
            "label": "docker: build master",
            "type": "shell",
            "command": "docker build -t xiaoyao9184/surya:master -f ./docker/build@source/dockerfile .",
        },
        {
            "label": "docker: build 0.20.0",
            "type": "shell",
            "command": "docker build -t xiaoyao9184/surya:0.20.0 -f ./docker/build@pypi/dockerfile .",
        },
        {
            "label": "hf: download models",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    // "HF_ENDPOINT": "https://hf-mirror.com",
                    // "HF_HUB_ETAG_TIMEOUT": "1000",
                    // "HF_HUB_DOWNLOAD_TIMEOUT": "1000"
                }
            },
            "command": [
                "hf download datalab-to/surya-ocr-2 --repo-type model --revision main --cache-dir ./cache/huggingface/hub",
                "&& hf download xiaoyao9184/surya_text_detection --repo-type model --revision 2025_05_07 --local-dir ./cache/datalab/models/text_detection/2025_05_07",
                "&& hf download xiaoyao9184/surya_ocr_error_detection --repo-type model --revision 2025_02_18 --local-dir ./cache/datalab/models/ocr_error_detection/2025_02_18",
            ]
        },
        {
            "label": "conda: pytest label-studio-ml",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/",
                "env": {
                    // "LABEL_STUDIO_URL": "http://localhost:8080",
                    // "LABEL_STUDIO_API_KEY": "<your-label-studio-api-key>",
                    // "HF_ENDPOINT": "https://hf-mirror.com",
                    // "HF_HUB_ETAG_TIMEOUT": "1000",
                    // "HF_HUB_DOWNLOAD_TIMEOUT": "1000",
                    "XDG_CACHE_HOME": "${workspaceFolder}/cache"
                }
            },
            "command": [
                "conda run -n surya pytest ${workspaceFolder}/label/test_api.py"
            ],
            "problemMatcher": []
        },
        {
            "label": "conda: start label-studio-ml",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/",
                "env": {
                    // "LABEL_STUDIO_URL": "http://localhost:8080",
                    // "LABEL_STUDIO_API_KEY": "<your-label-studio-api-key>",
                    // "HF_ENDPOINT": "https://hf-mirror.com",
                    // "HF_HUB_ETAG_TIMEOUT": "1000",
                    // "HF_HUB_DOWNLOAD_TIMEOUT": "1000",
                    "XDG_CACHE_HOME": "${workspaceFolder}/cache",
                    "DOCKER_HF_CACHE_PATH": "${workspaceFolder}/cache/huggingface",
                }
            },
            "command": [
                "conda run --no-capture-output -n surya label-studio-ml start --root-dir ${workspaceFolder} label"
            ],
            "problemMatcher": []
        },
        {
            "label": "conda: run gradio_app",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/",
                "env": {
                    // "HF_ENDPOINT": "https://hf-mirror.com",
                    // "HF_HUB_ETAG_TIMEOUT": "1000",
                    // "HF_HUB_DOWNLOAD_TIMEOUT": "1000",
                    "XDG_CACHE_HOME": "${workspaceFolder}/cache",
                    "DOCKER_HF_CACHE_PATH": "${workspaceFolder}/cache/huggingface",
                }
            },
            "command": [
                "conda run --no-capture-output -n surya gradio gradio/gradio_app.py"
            ],
            "problemMatcher": []
        },
        {
            "label": "conda: run surya_gui",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/surya",
                "env": {
                    // "HF_ENDPOINT": "https://hf-mirror.com",
                    // "HF_HUB_ETAG_TIMEOUT": "1000",
                    // "HF_HUB_DOWNLOAD_TIMEOUT": "1000",
                    "STREAMLIT_SERVER_PORT": "8501",
                    "XDG_CACHE_HOME": "${workspaceFolder}/cache",
                    "DOCKER_HF_CACHE_PATH": "${workspaceFolder}/cache/huggingface",
                },
            },
            "command": [
                "conda run --no-capture-output -n surya poetry run surya_gui"
            ]
        },
        {
            "label": "conda: create env",
            "type": "shell",
            "command": [
                "conda env create -f ./environment.yml",
                "&& conda run --no-capture-output -n surya pip install --no-deps git+https://github.com/HumanSignal/label-studio-ml-backend.git@b06ebeb#egg=label-studio-ml"
            ]
        }
    ]
}